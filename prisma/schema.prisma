generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./luxestate.db"
}

model User {
  extraListings Int @default(0)
  role            String   @default("user")
  id              Int      @id @default(autoincrement())
  email           String   @unique
  password        String
  name            String?
  phone           String?
  offers          Offer[]
  createdAt       DateTime @default(now())
  searchType      String?
  searchDistricts String?
  searchMaxPrice  Int?
  searchAreaTo    Int?
  searchPlotArea  Int?
  searchAmenities String?
  financing       String?
  buyerType       String   @default("private")
  isVerified      Boolean  @default(false)
  otpCode         String?
  otpExpiry       DateTime?
  isPro         Boolean      @default(false)
  proExpiresAt  DateTime?
  planType     PlanType     @default(NONE)
  searchAreaFrom  Int?
  searchRooms     Int?

  @@index([email])
}


enum PlanType {
  NONE
  INVESTOR
  AGENCY
}

model Offer {
  expiresAt DateTime?
  apartmentNumber String?
  id              Int      @id @default(autoincrement())
  title           String
  propertyType    String   @default("Mieszkanie")
  district        String   @default("Śródmieście")
  price           String
  area            String
  description     String?
  address         String?
  imageUrl        String   @default("https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?q=80&w=2075&auto=format&fit=crop")
  images          String?
  status          String   @default("pending")
  contactName     String?
  contactPhone    String?
  lat             Float    @default(52.2297)
  lng             Float    @default(21.0122)
  views           Int      @default(0)
  userId          Int?
  user            User?    @relation(fields: [userId], references: [id])
  createdAt       DateTime @default(now())
  advertiserType  String   @default("private")
  agencyName      String?
  rooms           String?
  floor           String?
  heating         String?
  year            String?
  plotArea        String?
  amenities       String?
  floorPlan       String?

  @@index([userId])
  @@index([district])
  @@index([status])
}

model Alert {
  id           Int      @id @default(autoincrement())
  email        String
  propertyType String   @default("Wszystkie")
  district     String   @default("Wszystkie")
  maxPrice     Int
  createdAt    DateTime @default(now())

  @@index([email])
  @@index([district])
}

model SiteVisit {
  id        Int      @id @default(autoincrement())
  ip        String
  country   String   @default("PL")
  path      String
  createdAt DateTime @default(now())

  @@index([ip])
  @@index([path])
}

model Appointment {
  id           String   @id @default(cuid())
  offerId      String
  buyerId      String
  sellerId     String
  status       String   @default("PROPOSED")
  proposedDate DateTime
  message      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([offerId])
  @@index([buyerId])
  @@index([sellerId])
  @@index([status])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String  
  isRead    Boolean  @default(false)
  link      String?
  type      String   @default("INFO")
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([isRead])
}

model Review {
  id         String   @id @default(cuid())
  reviewerId String
  targetId   String
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())

  @@index([targetId])
}

model Bid {
  id        String   @id @default(cuid())
  offerId   String
  buyerId   String
  sellerId  String
  amount    Int
  financing String   @default("CASH")
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([offerId])
  @@index([sellerId])
  @@index([status])
}

model LeadTransfer {
  commissionRate  Float?
  commissionTerms String?
  id        String   @id @default(cuid())
  offerId   Int
  ownerId   String
  agencyId  String
  status    String   @default("PENDING")
  createdAt DateTime @default(now())

  @@index([offerId])
  @@index([ownerId])
}

model DealMessage {
  id             String   @id @default(cuid())
  dealId         String
  senderId       String
  senderName     String?
  text           String
  attachmentUrl  String?
  attachmentType String?
  createdAt      DateTime @default(now())

  @@index([dealId])
}


model CalendarNote {
  id        Int      @id @default(autoincrement())
  userId    Int
  date      String   // Format: YYYY-MM-DD
  text      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
}
