generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ----------------------------------------------------
// 1. ENUMY - Słowniki systemu
// ----------------------------------------------------
enum Role {
  USER
  AGENT
  ADMIN
}

enum PlanType {
  NONE
  PRO
  AGENCY
}

enum OfferStatus {
  PENDING
  ACTIVE
  REJECTED
  ARCHIVED
  SOLD
  RENTED
}

// ----------------------------------------------------
// 2. MODEL UŻYTKOWNIKA (CRM & Auth)
// ----------------------------------------------------
model User {
  id            Int       @id @default(autoincrement())
  email         String    @unique
  phone         String?   @unique
  password      String?  
  name          String?
  image         String?   @db.Text
  
  // Dane firmowe (Dla Partnerów)
  companyName   String?
  nip           String?
  
  role          Role      @default(USER)
  planType      PlanType  @default(NONE)
  extraListings Int       @default(0)
  proExpiresAt  DateTime?
  
  expoPushToken String?  

  isVerified    Boolean   @default(false)
  otpCode       String?
  otpExpiry     DateTime?
  
  // Oś czasu
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  offers        Offer[]
  accounts      Account[]
  sessions      Session[]
  Authenticator Authenticator[]
}

// ----------------------------------------------------
// 3. MODEL OFERTY (Pełen silnik EstateOS)
// ----------------------------------------------------
model Offer {
  id              Int         @id @default(autoincrement())
  title           String
  description     String?     @db.Text
  
  // Kategoryzacja
  transactionType String      @default("SALE")
  propertyType    String      @default("APARTMENT")
  condition       String      @default("READY")
  
  // Finanse
  price           Float
  pricePerSqm     Float?
  adminFee        Float?
  deposit         Float?
  
  // Metryka
  area            Float
  plotArea        Float?
  rooms           Int?
  floor           Int?
  totalFloors     Int?
  yearBuilt       Int?
  
  // Udogodnienia (Filtry)
  hasBalcony      Boolean     @default(false)
  hasElevator     Boolean     @default(false)
  hasStorage      Boolean     @default(false)
  hasParking      Boolean     @default(false)
  hasGarden       Boolean     @default(false)
  isFurnished     Boolean     @default(false)
  petsAllowed     Boolean     @default(false)
  airConditioning Boolean     @default(false)
  
  // Lokalizacja i Radar
  city            String      @default("Warszawa")
  district        String      @default("OTHER")
  street          String?
  buildingNumber  String?
  lat             Float?
  lng             Float?
  isExactLocation Boolean     @default(true)
  
  // Media
  images          String?     @db.Text
  videoUrl        String?
  floorPlanUrl    String?
  
  // Status Cyklu Życia Ogłoszenia
  status          OfferStatus @default(PENDING)
  expiresAt       DateTime?   // Kiedy znika do archiwum (30 dni)
  promotedUntil   DateTime?   // Kiedy kończy się promowanie
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  
  // Właściciel / Agent
  userId          Int
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ----------------------------------------------------
// 4. MODELE NEXT-AUTH (Logowanie systemowe)
// ----------------------------------------------------
model Account {
  id                String  @id @default(cuid())
  userId            Int
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       Int
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Authenticator {
  credentialID         String  @unique
  userId               Int
  providerAccountId    String
  credentialPublicKey  String
  counter              Int
  credentialDeviceType String
  credentialBackedUp   Boolean
  transports           String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, credentialID])
}
